# Copy file này thành .env.fastlane rồi điền giá trị thực
# Đừng commit .env.fastlane lên git!

# ─── iOS ──────────────────────────────────────────────────────────────────────
IOS_APP_IDENTIFIER=com.yourcompany.heroui
APPLE_ID=your@email.com
ITC_TEAM_ID=                        # App Store Connect Team ID (số)
TEAM_ID=                            # Apple Developer Team ID (chữ)

# Match — private Git repo lưu certificates
MATCH_GIT_URL=git@github.com:yourorg/certs-heroui.git
MATCH_PASSWORD=                     # Password để encrypt/decrypt certs

# App Store Connect API Key (thay thế cho password — khuyến nghị)
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_CONTENT=  # Nội dung file .p8 (một dòng, có \n)

# ─── Android ──────────────────────────────────────────────────────────────────
ANDROID_PACKAGE_NAME=com.heroui
GOOGLE_PLAY_JSON_KEY_PATH=fastlane/google-play-key.json

# Android Keystore
KEYSTORE_PATH=/path/to/heroui.jks
KEYSTORE_PASSWORD=
KEY_ALIAS=
KEY_PASSWORD=

# ─── Misc ─────────────────────────────────────────────────────────────────────
CHANGELOG=
