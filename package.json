{
  "name": "heroui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "android:staging": "ENVFILE=.env.staging react-native run-android",
    "android:prod": "ENVFILE=.env.production react-native run-android",
    "ios": "react-native run-ios",
    "ios:staging": "echo .env.staging > /tmp/envfile && react-native run-ios",
    "ios:prod": "echo .env.production > /tmp/envfile && react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "storybook": "STORYBOOK_ENABLED=true react-native start --reset-cache",
    "test": "jest",
    "test:ci": "jest --ci --coverage --forceExit --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e:ios:build": "detox build --configuration ios.sim.release",
    "test:e2e:ios": "detox test --configuration ios.sim.release --cleanup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "heroui-native": "^1.0.0-rc.4",
    "i18next": "^25.8.14",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "react-native": "0.84.1",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-localize": "^3.7.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "^0.7.4",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.1",
    "uniwind": "^1.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-backgrounds": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/addon-ondevice-notes": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-inline-environment-variables": "^0.4.4",
    "detox": "^20.47.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "msw": "^2.12.10",
    "node-fetch": "^3.3.2",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "storybook": "^10.2.16",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
